# service name: /hal/arm_force_cal
std_msgs/Header     header
int32               cal_cmd       # 1: 标定六维力数据
uint32              force_id      # 0x00 = left | end, 0x01 = right | end, 0x02 = both
int8                count
float32[]           joint
bool                block         #暂时未用，默认阻塞
---
std_msgs/Header     res_header
# 0: success, 1: 控制器返回错误或参数错误 2:数据发送失败
# 3: 数据接收失败或超时 4:返回值解析失败 5:程序发生异常 6:不支持的手臂标定类型
# 7: 未知错误 8: 不支持的标定类型 9:不支持的标定cmd
uint8               exec_result    